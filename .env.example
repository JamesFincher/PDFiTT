# Public origin for this deployment, without a trailing slash.
# Used by /mcp setup instructions.
PDFITT_PUBLIC_URL=https://your-pdf-tool.vercel.app

# Optional comma-separated origin allowlist for browser/API/MCP requests.
# Leave unset for same-host and localhost development defaults.
PDFITT_ALLOWED_ORIGINS=https://your-pdf-tool.vercel.app

# Optional convenience value for the local skill script.
PDFITT_MCP_URL=https://your-pdf-tool.vercel.app/mcp
